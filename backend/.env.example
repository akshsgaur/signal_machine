DATABASE_URL=postgresql://user:password@host:5432/database
BACKEND_PUBLIC_URL=https://your-backend-host
OPENAI_API_KEY=your-openai-key
AIRBYTE_CLIENT_ID=your-airbyte-client-id
AIRBYTE_CLIENT_SECRET=your-airbyte-client-secret
AIRBYTE_ORGANIZATION_ID=your-airbyte-organization-id
MACROSCOPE_CALLBACK_TOKEN=optional-shared-token
# Optional: Productboard sidecar path
PRODUCTBOARD_SIDECAR_PATH=/path/to/productboard-mcp/index.js
